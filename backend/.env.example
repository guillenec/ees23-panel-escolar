APP_NAME=EES23 API
APP_ENV=development
API_V1_PREFIX=/api/v1
DATABASE_URL=postgresql+psycopg://ees23:ees23@localhost:5432/ees23

# === SECURITY ===
JWT_SECRET_KEY=change-me-in-env
JWT_ALGORITHM=HS256
ACCESS_TOKEN_MINUTES=60
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# === GOOGLE OAUTH ===
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback

# === OPENROUTER (optional, for YouTube metadata suggestions) ===
OPENROUTER_API_KEY=
OPENROUTER_MODEL=arcee-ai/trinity-large-preview:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# === GOOGLE DRIVE SERVICE ACCOUNT (MVP) ===
GOOGLE_DRIVE_SERVICE_ACCOUNT_FILE=
GOOGLE_DRIVE_ROOT_FOLDER_ID=
GOOGLE_DRIVE_SOURCE=personal
